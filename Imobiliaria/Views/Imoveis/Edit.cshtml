@model Imobiliaria.Models.Imovel

<h2>Editar Imóvel</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label>Título</label>
        <input asp-for="Titulo" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Bairro</label>
        <input asp-for="Bairro" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Valor do Aluguel</label>
        <input asp-for="ValorAluguel" type="number" step="0.01" class="form-control" required />
    </div>
    <br />
    <button type="submit" class="btn btn-primary">Atualizar</button>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</form>
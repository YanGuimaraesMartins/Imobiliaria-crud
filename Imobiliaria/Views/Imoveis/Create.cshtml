@model Imobiliaria.Models.Imovel

<h2>Cadastrar Novo Imóvel</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Título</label>
        <input asp-for="Titulo" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Bairro</label>
        <input asp-for="Bairro" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Valor do Aluguel</label>
        <input asp-for="ValorAluguel" type="number" step="0.01" class="form-control" required />
    </div>
    <br />
    <button type="submit" class="btn btn-success">Salvar Imóvel</button>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</form>